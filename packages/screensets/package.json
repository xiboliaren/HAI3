{
  "name": "@hai3/screensets",
  "version": "0.4.0-alpha.2",
  "description": "Pure TypeScript contracts and registry for HAI3 screenset management",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./plugins/gts": {
      "types": "./dist/mfe/plugins/gts/index.d.ts",
      "import": "./dist/mfe/plugins/gts/index.js",
      "require": "./dist/mfe/plugins/gts/index.cjs"
    },
    "./mfe/handler": {
      "types": "./dist/mfe/handler/index.d.ts",
      "import": "./dist/mfe/handler/index.js",
      "require": "./dist/mfe/handler/index.cjs"
    }
  },
  "files": [
    "dist",
    "CLAUDE.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "hai3",
    "screensets",
    "contracts",
    "typescript",
    "vertical-slices"
  ],
  "author": "HAI3",
  "license": "Apache-2.0",
  "dependencies": {
    "@globaltypesystem/gts-ts": "^0.3.0"
  }
}
